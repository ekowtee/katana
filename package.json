{
  "name": "fellowship_launch",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.mjs",
    "dev:all": "concurrently -n vite,api -c green,yellow \"vite\" \"node server/index.mjs\"",
    "ingest": "node scripts/ingest.mjs",
    "db:schema": "psql -h localhost -p 5432 -U postgres -d datjf_portal -f server/sql/schema.sql",
    "db:seed": "psql -h localhost -p 5432 -U postgres -d datjf_portal -f supabase/seed.sql",
    "db:accounts": "node scripts/seed-accounts.mjs",
    "db:feedback": "node scripts/draft-feedback.mjs",
    "cloud:schema": "psql \"$DATABASE_URL\" -f server/sql/schema.sql",
    "cloud:seed": "psql \"$DATABASE_URL\" -f supabase/seed.sql",
    "cloud:push": "npm run cloud:schema && npm run cloud:seed && npm run db:accounts && npm run db:feedback",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@paystack/inline-js": "^2.22.7",
    "@supabase/supabase-js": "^2.101.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.0.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.454.0",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "react-paystack": "^6.0.0",
    "react-router-dom": "^6.26.2",
    "react-slick": "^0.30.2",
    "react-toastify": "^11.0.5",
    "recharts": "^3.7.0",
    "slick-carousel": "^1.8.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-motion": "^0.4.1-beta",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "aos": "^2.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "postcss": "^8.4.45",
    "puppeteer-core": "^25.1.0",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.1"
  }
}
